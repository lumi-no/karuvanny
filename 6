#include <iostream>
#include <functional>
#include <string>

using namespace std;

function<string(string)> message(string prefix)
{
    return [prefix](string text)
    {
        return prefix + ": " + text;
    };
}

int main()
{

    function<string(string)> errorMessage =
        message("ERROR");

    function<string(string)> warningMessage =
        message("WARNING");

    function<string(string)> infoMessage =
        message("INFO");
    cout << errorMessage("File not found") << endl;

    cout << warningMessage("Low memory") << endl;

    cout << infoMessage("Process started") << endl;

    return 0;
}
