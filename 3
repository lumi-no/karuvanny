#include <iostream>
#include <functional>

using namespace std;

function<int(int)> addCurried(int a)
{
    return [a](int b)
    {
        return a + b;
    };
}

int main()
{
    cout << addCurried(2)(3) << endl;

    cout << addCurried(10)(5) << endl;

    function<int(int)> add10 =
        addCurried(10);

    cout << add10(7) << endl;

    cout << add10(100) << endl;

    return 0;
}
