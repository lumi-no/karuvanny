Карування (currying) — це коли функція приймає лише один аргумент за виклик та повертає іншу функцію для наступного аргументу. А тут функції одразу приймають всі аргументи. Скільки аргументів приймає кожна функція: 
Add 2 
Multiply 2 
Power 2

#include <iostream>
#include <cmath>

using namespace std;

int add(int a, int b)
{
    return a + b;
}

int multiply(int a, int b)
{
    return a * b;
}

double power(double base, double exponent)
{
    return pow(base, exponent);
}

int main()
{
    cout << add(2, 3) << endl;

    cout << multiply(4, 5) << endl;

    cout << power(2, 3) << endl;

    return 0;
}
